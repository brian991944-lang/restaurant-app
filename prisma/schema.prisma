// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String   @id @default(cuid())
  name         String?
  email        String?  @unique
  passwordHash String?
  role         String   @default("KITCHEN") // KITCHEN, SALON, ADMIN
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  prepAssignments      PrepAssignment[]
  completedAssignments PrepAssignmentCompletedBy[]
}

model Provider {
  id          String       @id @default(cuid())
  name        String
  ingredients Ingredient[]
}

model Category {
  id             String          @id @default(cuid())
  name           String
  nameEs         String?
  type           String          @default("INGREDIENT") // INGREDIENT, TASK, RECIPE
  autoTranslate  Boolean         @default(true)
  department     String // FOOD, DRINKS, CLEANING
  cookAssignment Int?            @default(1) // 1 or 2
  ingredients    Ingredient[]
  digitalRecipes DigitalRecipe[]
}

model Ingredient {
  id             String    @id @default(cuid())
  name           String    @unique
  nameEs         String?
  autoTranslate  Boolean   @default(true)
  type           String // RAW, PROCESSED
  categoryId     String
  category       Category  @relation(fields: [categoryId], references: [id])
  providerId     String?
  provider       Provider? @relation(fields: [providerId], references: [id])
  portionWeightG Float     @default(1000.0)
  metric         String    @default("units")
  currentPrice   Float     @default(0.0)
  yieldPercent   Float     @default(100.0)
  aliases        String? // JSON string
  trackFreezerStatus Boolean @default(false)
  unfrozenQuantity Float @default(0)
  allowNegativeStock Boolean @default(true)
  subtractFromInventory Boolean @default(false)
  cookAssignmentOverride Int? // null = inherit from category
  
  isPacked       Boolean @default(false)
  unitsPerPack   Float   @default(1.0)
  packUnit       String  @default("Units")
  packsInBox     Float?
  totalBoxPrice  Float?
  needsOrdering  Boolean @default(false)
  isSubmittedForOrdering Boolean @default(false)
  purchaseStatus String  @default("PENDIENTE")   // PENDIENTE | COMPRADO | NO_DISPONIBLE
  carriedOver    Boolean @default(false)
  isActive       Boolean @default(true)           // soft-disable: false = hidden from cook-facing lists
  esfuerzo       String  @default("MANUAL")       // MANUAL | HERVIDO
  updatedAt      DateTime  @default(now()) @updatedAt

  parentId  String?
  parent    Ingredient?  @relation("IngredientToPrep", fields: [parentId], references: [id])
  prepItems Ingredient[] @relation("IngredientToPrep")

  inventory         Inventory?
  transactions      InventoryTransaction[]
  recipeIngredients RecipeIngredient[]
  prepAssignments   PrepAssignment[]
  vendorMarketItems VendorMarketItem[]
  
  // Rules
  isRuleTarget    RecurringPrepRule[] @relation("RuleTarget")
  isRuleBase      RecurringPrepRule[] @relation("RuleBase")
  prepRules       PrepRule[]

  composedOf  PrepRecipeIngredient[] @relation("RecipeComposedOf")
  usedInPreps PrepRecipeIngredient[] @relation("UsedInPreps")

  activeMarketItemId String?
  activeMarketItem   VendorMarketItem?    @relation("ActiveMarketItem", fields: [activeMarketItemId], references: [id])
  cloverId           String?
  mappingMultiplier  Float                @default(1.0)
  ModifierIngredient ModifierIngredient[]

  digitalRecipeId    String?
  digitalRecipe      DigitalRecipe?       @relation("IngredientToDigitalRecipe", fields: [digitalRecipeId], references: [id])
}

model ProcessedCloverLineItem {
  id               String   @id @default(cuid())
  cloverLineItemId String   @unique
  orderId          String
  processedAt      DateTime @default(now())

  itemName     String?
  categoryName String?
  createdTime  DateTime @default(now())
  qty          Int      @default(1)

  modifiers ProcessedCloverModifier[]
}

model ProcessedCloverModifier {
  id               String                  @id @default(cuid())
  cloverModifierId String                  @unique
  lineItemId       String
  lineItem         ProcessedCloverLineItem @relation(fields: [lineItemId], references: [id], onDelete: Cascade)
  modifierName     String?
  qty              Int                     @default(1)
}

model VendorMarketItem {
  id                 String     @id @default(cuid())
  ingredientId       String
  ingredient         Ingredient @relation(fields: [ingredientId], references: [id])
  vendorName         String?
  invoiceDescription String
  packSize           Float
  packUnit           String
  currentPackPrice   Float
  lastPurchasedDate  DateTime?
  culinaryNotes      String?
  isPreferredVendor  Boolean    @default(false)

  // Reverse relation for activeMarketItem
  activeForIngredients Ingredient[] @relation("ActiveMarketItem")
}

model MenuCategory {
  id        String   @id @default(cuid())
  nameEn    String
  nameEs    String
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  menuItems MenuItem[]
}

model MenuItem {
  id                    String  @id @default(cuid())
  name                  String  @unique
  category              String? // Ceviches, Appetizers, Entrees, Sauces
  salePrice             Float   @default(0.0)
  targetFoodCostPct     Float   @default(25.0)
  cloverId              String? // Integration point: Clover POS item id (menu <-> POS sync)
  hasInventoryModifiers Boolean @default(false)

  // Digital menu module — additive fields only (all optional/defaulted)
  nameEs          String?
  descriptionEn   String?
  descriptionEs   String?
  photoUrl        String?
  photoUrls       String[] @default([]) // gallery photos for the lightbox; photoUrl remains the card cover
  videoUrl        String?
  taglineEn       String? // short catchy "how we make it" line, shown in the lightbox (max 60 chars, enforced in menuAdmin actions)
  taglineEs       String?
  isAvailable     Boolean @default(true)
  isFeatured      Boolean @default(false)
  sortOrder       Int     @default(0)
  menuCategoryId  String? // Integration point: digital menu category (menu module)
  menuCategory    MenuCategory? @relation(fields: [menuCategoryId], references: [id])
  digitalRecipeId String? // Integration point: Recetario link for food-cost reporting
  digitalRecipe   DigitalRecipe? @relation(fields: [digitalRecipeId], references: [id])

  recipeIngredients RecipeIngredient[]
  modifiers         MenuItemModifier[]
}

model MenuItemModifier {
  id               String @id @default(cuid())
  menuItemId       String
  name             String
  cloverModifierId String

  menuItem    MenuItem             @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  ingredients ModifierIngredient[]
}

model ModifierIngredient {
  id           String  @id @default(cuid())
  modifierId   String
  ingredientId String
  quantity     Float
  unit         String?

  modifier   MenuItemModifier @relation(fields: [modifierId], references: [id], onDelete: Cascade)
  ingredient Ingredient       @relation(fields: [ingredientId], references: [id], onDelete: Restrict)
}

model RecipeIngredient {
  id           String  @id @default(cuid())
  menuItemId   String
  ingredientId String
  quantity     Float
  unit         String?

  menuItem   MenuItem   @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  ingredient Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Restrict)
}

model PrepRecipeIngredient {
  id           String  @id @default(cuid())
  prepRecipeId String
  ingredientId String
  quantity     Float
  unit         String?
  groupName    String?

  prepRecipe Ingredient @relation("RecipeComposedOf", fields: [prepRecipeId], references: [id], onDelete: Cascade)
  ingredient Ingredient @relation("UsedInPreps", fields: [ingredientId], references: [id], onDelete: Restrict)
}

model Inventory {
  id           String     @id @default(cuid())
  ingredientId String     @unique
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])
  frozenQty    Float      @default(0.0)
  thawingQty   Float      @default(0.0)
}

model InventoryTransaction {
  id           String     @id @default(cuid())
  ingredientId String
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])
  type         String // DEDUCT_FROZEN, ADD_THAWING, SALES_DEDUCT, PULL_PREP
  qty          Float
  note         String?
  createdAt    DateTime   @default(now())
}

model DailySales {
  id           String   @id @default(cuid())
  date         DateTime
  itemName     String
  modification String?
  qtySOLD      Float
  price        Float
  processedAt  DateTime @default(now())
}

model Schedule {
  id         String   @id @default(cuid())
  date       DateTime
  createdBy  String
  assignedTo String
  notes      String?

  prepAssignments PrepAssignment[]
}

model PrepAssignment {
  id               String    @id @default(cuid())
  scheduleId       String
  userId           String
  ingredientId     String
  portionsAssigned Float
  portionsActual   Float?
  completed        Boolean   @default(false)
  completedAt      DateTime?
  isUrgent         Boolean   @default(false)

  schedule        Schedule                    @relation(fields: [scheduleId], references: [id])
  user            User                        @relation(fields: [userId], references: [id])
  ingredient      Ingredient                  @relation(fields: [ingredientId], references: [id])
  completedByCooks PrepAssignmentCompletedBy[]
}

model DropdownOption {
  id           String   @id @default(cuid())
  group        String // Category, Type, Metric
  name         String
  nameEs       String?
  isTranslated Boolean  @default(true)
  createdAt    DateTime @default(now())
}

model RecurringPrepRule {
  id               String @id @default(cuid())
  ingredientId     String
  baseIngredientId String?
  dayOfWeek        Int // 0=Sun, 1=Mon, 2=Tue, 3=Wed, 4=Thu, 5=Fri, 6=Sat
  amount           Float // Represents Total Demand
  mode             String @default("MANUAL") // MANUAL or ALGORITHM

  ingredient     Ingredient @relation("RuleTarget", fields: [ingredientId], references: [id])
  baseIngredient Ingredient? @relation("RuleBase", fields: [baseIngredientId], references: [id])

  @@unique([ingredientId, dayOfWeek])
}

model PrepRule {
  id                 String     @id @default(cuid())
  ingredientId       String
  ingredient         Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  ruleType           String     @default("REGULAR") // REGULAR, EMERGENCY
  activeDays         Int[]      // Days of the week task appears (0-6)
  calculationMode    String     @default("ALGORITHM") // ALGORITHM, MANUAL
  fixedAmount        Float?
  coverageDays       Int[]      // Array of days it covers (0-6)
  emergencyDays      Int        @default(3)
  emergencyThreshold Float      @default(1.5)
  triggerThreshold   Float?
}

model DigitalRecipe {
  id              String   @id @default(cuid())
  type            String   // RECIPE, PLATING, GUIDE
  recipeCode      String   @unique
  name            String
  nameEs          String?
  yield           String?
  overview        String?
  ingredientsJson String?  // JSON text: [{ id, ingredient, quantity, metric, notes }]
  procedureJson   String?  // JSON text: array of steps/strings
  platingTracksJson String? // JSON text: { tracks: [], rows: [] }
  mediaJson       String?  // JSON text: final plated photo url
  chefNotes       String?
  revisionDate    DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  categoryId      String?
  category        Category? @relation(fields: [categoryId], references: [id])

  history         DigitalRecipeHistory[]
  linkedTasks     Ingredient[] @relation("IngredientToDigitalRecipe")
  menuItems       MenuItem[]
}

model DigitalRecipeHistory {
  id              String   @id @default(cuid())
  recipeId        String
  recipe          DigitalRecipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  type            String
  recipeCode      String
  name            String
  nameEs          String?
  yield           String?
  overview        String?
  ingredientsJson String?
  procedureJson   String?
  platingTracksJson String?
  mediaJson       String?
  chefNotes       String?
  revisionDate    DateTime
  savedAt         DateTime @default(now())
  savedBy         String?
}

model PrepAssignmentCompletedBy {
  id           String         @id @default(cuid())
  assignmentId String
  userId       String
  createdAt    DateTime       @default(now())
  assignment   PrepAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  user         User           @relation(fields: [userId], references: [id])

  @@unique([assignmentId, userId])
}
